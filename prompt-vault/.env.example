# Prompt-Vault Configuration
# Copy this file to .env and fill in your values.

# Secret used to encrypt/decrypt the prompt vault (required)
VAULT_SECRET=change-me-to-a-strong-random-secret

# Your Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Comma-separated list of API tokens for client authentication (required)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_TOKENS=token1,token2

# Server port (default: 3700)
PORT=3700

# Default Anthropic model (default: claude-sonnet-4-20250514)
DEFAULT_MODEL=claude-sonnet-4-20250514

# Max tokens per response (default: 4096)
MAX_TOKENS=4096
