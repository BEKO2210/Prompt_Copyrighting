---
const base = import.meta.env.BASE_URL;
---

<footer class="border-t border-armor-border mt-auto py-10">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Top row: branding + links -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 mb-8">
      <div>
        <a href={base} class="flex items-center gap-2 mb-2">
          <img src={`${base}logo.png`} alt="Prompt-Armor" width="24" height="24" class="object-contain" />
          <span class="text-armor-white font-semibold text-sm">Prompt-Armor</span>
        </a>
        <p class="text-armor-muted text-xs">Tamper-evident prompt protection</p>
      </div>
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-xs">
        <a href={`${base}imprint`} class="text-armor-muted hover:text-armor-white transition-colors">Imprint</a>
        <a href={`${base}privacy`} class="text-armor-muted hover:text-armor-white transition-colors">Privacy Policy</a>
        <a href={`${base}terms`} class="text-armor-muted hover:text-armor-white transition-colors">Terms of Service</a>
        <a href="https://github.com/BEKO2210/Prompt_Copyrighting" target="_blank" rel="noopener noreferrer" class="text-armor-muted hover:text-armor-white transition-colors">GitHub</a>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-armor-border pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-armor-muted">
      <p>
        Built by
        <a href="https://github.com/BEKO2210" target="_blank" rel="noopener noreferrer" class="text-armor-accent hover:text-armor-accent-hover transition-colors">
          Belkis Aslani
        </a>
      </p>
      <p>
        Currently free for personal use &mdash;
        <a href="mailto:belkis.aslani@gmail.com" class="text-armor-accent hover:text-armor-accent-hover transition-colors">
          Contact for commercial licensing
        </a>
      </p>
    </div>
  </div>
</footer>
