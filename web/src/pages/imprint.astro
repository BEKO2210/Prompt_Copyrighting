---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Imprint -- Prompt-Armor" description="Legal disclosure (Impressum) for Prompt-Armor as required by German law.">
  <Header />

  <main class="flex-1 max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold text-armor-white mb-8">Imprint</h1>
    <p class="text-xs text-armor-muted mb-8">Legal disclosure pursuant to Sec. 5 TMG (German Telemedia Act)</p>

    <div class="space-y-8 text-sm text-armor-text leading-relaxed">

      <section>
        <h2 class="text-lg font-semibold text-armor-white mb-3">Information pursuant to Sec. 5 German Telemedia Act (TMG)</h2>
        <p>
          Belkis Aslani<br/>
          Vogelsangstr. 32<br/>
          71691 Freiberg am Neckar<br/>
          Germany
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-armor-white mb-3">Contact</h2>
        <p>
          Email:
          <a href="mailto:belkis.aslani@gmail.com" class="text-armor-accent hover:text-armor-accent-hover transition-colors">
            belkis.aslani@gmail.com
          </a>
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-armor-white mb-3">Responsible for content pursuant to Sec. 55 para. 2 RStV</h2>
